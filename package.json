{
  "name": "systemiq",
  "version": "1.0.0",
  "description": "SystemIQ - AI-powered Windows intelligence platform for developers and power users",
  "main": "dist-electron/main.js",
  "author": "WIO Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && electron-builder",
    "build:dir": "npm run typecheck && vite build && electron-builder --dir",
    "build:nsis": "npm run typecheck && vite build && electron-builder --win nsis",
    "build:msi": "npm run typecheck && vite build && electron-builder --win msi",
    "build:zip": "npm run typecheck && vite build && electron-builder --win zip",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "rebuild": "npx electron-rebuild",
    "clean": "rimraf dist dist-electron release",
    "dist": "npm run clean && npm run build",
    "dist:nsis": "npm run clean && npm run build:nsis",
    "dist:msi": "npm run clean && npm run build:msi",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "11.8.0",
    "date-fns": "^3.3.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "filesize": "^10.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "systeminformation": "^5.22.0",
    "uuid": "^14.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "33.4.11",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.35",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.1",
    "terser": "^5.48.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "overrides": {
    "electron": "33.4.11"
  },
  "build": {
    "appId": "com.wio.systemiq",
    "productName": "SystemIQ",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SystemIQ"
    },
    "msi": {
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
